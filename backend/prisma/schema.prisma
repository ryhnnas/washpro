// =============================================
// PRISMA SCHEMA - Laundry POS (Multi-Tenant)
// Versi SaaS + Strategic Indexing
// =============================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

// =============================================
// 0. SUPERADMIN & SUBSCRIPTION SYSTEM
// =============================================

model SuperAdmin {
  id        String   @id @default(uuid())
  name      String
  email     String   @unique
  password  String
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
}

model SubscriptionPlan {
  id           String   @id @default(uuid())
  name         String
  price        Int
  durationDays Int      @default(30) @map("duration_days")
  features     Json?
  isActive     Boolean  @default(true) @map("is_active")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  payments SubscriptionPayment[]
}

enum SubscriptionStatus {
  TRIAL
  PENDING_PAYMENT
  ACTIVE
  EXPIRED
  SUSPENDED
}

enum PaymentStatus {
  PENDING
  APPROVED
  REJECTED
}

model SubscriptionPayment {
  id              String        @id @default(uuid())
  businessId      String        @map("business_id")
  planId          String        @map("plan_id")
  uploadedByUserId String?      @map("uploaded_by_user_id")
  amount          Int
  proofOfPayment  String        @db.Text @map("proof_of_payment")
  status          PaymentStatus @default(PENDING)
  paymentMethod   String        @default("QRIS_DANA") @map("payment_method")
  approvedAt      DateTime?     @map("approved_at")
  approvedById    String?       @map("approved_by_id")
  adminEmailNotifiedAt DateTime? @map("admin_email_notified_at")
  rejectionReason String?       @db.Text @map("rejection_reason")
  createdAt       DateTime      @default(now()) @map("created_at")
  updatedAt       DateTime      @updatedAt @map("updated_at")

  business Business         @relation(fields: [businessId], references: [id], onDelete: Cascade)
  plan     SubscriptionPlan @relation(fields: [planId], references: [id])
  uploadedBy User?          @relation("UserUploadedPayments", fields: [uploadedByUserId], references: [id], onDelete: SetNull)

  @@index([businessId, status])
  @@index([status])
  @@index([uploadedByUserId])
}

// =============================================
// 1. BUSINESS (Tenant)
// =============================================
model Business {
  id        String   @id @default(uuid())
  name      String
  address   String?  @db.Text
  phone     String?
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // SaaS Subscription Fields
  subscriptionStatus SubscriptionStatus @default(TRIAL) @map("subscription_status")
  trialEndAt         DateTime?          @map("trial_end_at")
  subscriptionEndAt  DateTime?          @map("subscription_end_at")
  deletedAt          DateTime?          @map("deleted_at")

  users                       User[]
  transactions                Transaction[]
  services                    Service[]
  setting                     BusinessSetting?
  customers                   Customer[]
  membershipPackageTemplates  MembershipPackageTemplate[]
  whatsappSession             WhatsAppSession?
  whatsAppQueues              WhatsAppQueue[]
  subscriptionPayments        SubscriptionPayment[]
}

// =============================================
// 2. USER
// =============================================
model User {
  id         String   @id @default(uuid())
  businessId String   @map("business_id")
  name       String
  email      String   @unique
  phone      String?
  password   String
  role       Role     @default(STAFF)
  isEmailVerified Boolean @default(false) @map("is_email_verified")
  mustChangePassword Boolean @default(false) @map("must_change_password")
  sessionVersion Int  @default(0) @map("session_version")

  resetPasswordToken   String?   @unique @map("reset_password_token")
  resetPasswordExpires DateTime? @map("reset_password_expires")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  business          Business           @relation(fields: [businessId], references: [id])
  transactions      Transaction[]
  passwordResetOtps PasswordResetOtp[]
  refreshTokens     RefreshToken[]
  emailVerificationOtps EmailVerificationOtp[]
  uploadedPayments SubscriptionPayment[] @relation("UserUploadedPayments")

  @@index([businessId])
}

model EmailVerificationOtp {
  id        String    @id @default(uuid())
  userId    String    @map("user_id")
  otp       String
  expiresAt DateTime  @map("expires_at")
  usedAt    DateTime? @map("used_at")
  attempts  Int       @default(0)
  createdAt DateTime  @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, expiresAt])
}

enum Role {
  OWNER
  STAFF
}

// =============================================
// 2b. REFRESH TOKEN
// =============================================
model RefreshToken {
  id        String    @id @default(uuid())
  userId    String    @map("user_id")
  tokenHash String    @map("token_hash")    // SHA-256 hash of the refresh token
  expiresAt DateTime  @map("expires_at")
  revokedAt DateTime? @map("revoked_at")
  userAgent String?   @db.Text @map("user_agent")
  createdAt DateTime  @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, revokedAt])
  @@index([tokenHash])
}

// =============================================
// 2c. PASSWORD RESET OTP
// =============================================
model PasswordResetOtp {
  id        String    @id @default(uuid())
  userId    String    @map("user_id")
  otp       String                          // Hashed (bcrypt)
  expiresAt DateTime  @map("expires_at")
  usedAt    DateTime? @map("used_at")
  attempts  Int       @default(0)           // Max 5 percobaan
  createdAt DateTime  @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, expiresAt])
}

// =============================================
// 3. SERVICE
// =============================================
model Service {
  id             String       @id @default(uuid())
  businessId     String       @map("business_id")
  name           String
  price          Int
  type           ServiceType
  unit           String       @default("kg")
  estimateValue  Int          @default(24) @map("estimate_value")
  estimateUnit   EstimateUnit @default(HOUR) @map("estimate_unit")
  isActive       Boolean      @default(true) @map("is_active")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  business Business @relation(fields: [businessId], references: [id])

  packageQuotaItems  MembershipPackageQuotaItem[]
  membershipBalances CustomerMembershipQuotaBalance[]
  membershipUsages   CustomerMembershipUsageLog[]

  @@index([businessId])
  @@index([businessId, isActive]) // Untuk filter layanan aktif
}

enum ServiceType {
  KILOAN
  SATUAN
}

enum EstimateUnit {
  HOUR
  DAY
}

// =============================================
// 4. TRANSACTION (Paling Penting - Banyak Index)
// =============================================
model Transaction {
  id                   String   @id @default(uuid())
  businessId           String   @map("business_id")
  customerId           String?  @map("customer_id")
  customerMembershipId String?  @map("customer_membership_id")
  createdByUserId      String?  @map("created_by_user_id")
  customerName         String   @map("customer_name")
  customerPhone        String?  @map("customer_phone")
  customerAddress      String?  @db.Text @map("customer_address")

  serviceName   String  @map("service_name")
  weight        Float
  lineItems     Json?   @map("line_items")
  totalPrice    Int     @map("total_price")
  coveredAmount Int     @default(0) @map("covered_amount")
  payableAmount Int     @default(0) @map("payable_amount")

  status        Status  @default(PENDING)
  paymentMethod Payment @map("payment_method")

  startDate               DateTime  @default(now()) @map("start_date")
  endDate                 DateTime? @map("end_date")
  estimatedCompletionAt   DateTime? @map("estimated_completion_at")
  isOverdue               Boolean   @default(false) @map("is_overdue")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  

  business           Business           @relation(fields: [businessId], references: [id])
  customer           Customer?          @relation(fields: [customerId], references: [id])
  customerMembership CustomerMembership? @relation(fields: [customerMembershipId], references: [id])
  membershipUsageLogs CustomerMembershipUsageLog[]
  createdBy          User?              @relation(fields: [createdByUserId], references: [id])

  // ==================== STRATEGIC INDEXES ====================
  @@index([businessId, startDate])           // Laporan harian/mingguan
  @@index([businessId, status])              // Filter pesanan aktif
  @@index([businessId, customerPhone])       // Cari transaksi by HP
  @@index([businessId, isOverdue])           // Filter overdue
  @@index([status, startDate])               // Global query (opsional)
}

// =============================================
// 5. BUSINESS SETTING
// =============================================
model BusinessSetting {
  id         String @id @default(uuid())
  businessId String @unique @map("business_id")

  requireCustomerName    Boolean @default(true)
  requireCustomerPhone   Boolean @default(true)
  requireCustomerAddress Boolean @default(false)

  // Staff Permissions (Broken down from JSON string)
  allowStaffDashboard    Boolean @default(true)  @map("allow_staff_dashboard")
  allowStaffCustomers    Boolean @default(true)  @map("allow_staff_customers")
  allowStaffServices     Boolean @default(false) @map("allow_staff_services")
  allowStaffReports      Boolean @default(false) @map("allow_staff_reports")

  membershipPackageName   String  @default("Paket Membership") @map("membership_package_name")
  membershipDurationDays  Int     @default(30) @map("membership_duration_days")
  
  whatsappTemplates       String? @db.Text @map("whatsapp_templates") // Menyimpan object template (RECEIPT, PROSES, dll)
  whatsappReceiptTemplate String? @db.Text @map("whatsapp_receipt_template")
  whatsappNotificationStates String? @db.Text @map("whatsapp_notification_states")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  business Business @relation(fields: [businessId], references: [id])
}

// =============================================
// 6. WHATSAPP SESSION
// =============================================
model WhatsAppSession {
  businessId    String    @id @unique @map("business_id")
  phoneNumber   String?   @map("phone_number")
  status        String    @default("disconnected")
  connectedVia  String?   @map("connected_via")
  lastConnected DateTime? @map("last_connected")
  lastError     String?   @db.Text @map("last_error")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  business Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  @@index([status]) // Untuk cek session aktif
}

// =============================================
// 7. WHATSAPP QUEUE (Antrian Pesan)
// =============================================
model WhatsAppQueue {
  id            String   @id @default(uuid())
  businessId    String   @map("business_id")
  customerPhone String   @map("customer_phone")
  message       String   @db.Text
  status        String   @default("PENDING") // PENDING, SENT, FAILED, RETRYING
  attempts      Int      @default(0)
  lastError     String?  @db.Text @map("last_error")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  business Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  // ==================== STRATEGIC INDEXES ====================
  @@index([businessId, status])           // Ambil antrian per bisnis
  @@index([status, createdAt])            // Proses antrian global
  @@index([businessId, status, attempts]) // Retry logic
}

// =============================================
// 8. CUSTOMER
// =============================================
model Customer {
  id         String   @id @default(uuid())
  businessId String   @map("business_id")
  name       String
  phone      String?
  address    String?  @db.Text
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  business     Business      @relation(fields: [businessId], references: [id])
  transactions Transaction[]
  memberships  CustomerMembership[]

  @@unique([businessId, phone])
  @@index([businessId, name]) // Pencarian pelanggan by nama
}

// =============================================
// 9. MEMBERSHIP SYSTEM
// =============================================
model MembershipPackageTemplate {
  id           String   @id @default(uuid())
  businessId   String   @map("business_id")
  name         String
  durationDays Int      @default(30) @map("duration_days")
  isActive     Boolean  @default(true) @map("is_active")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  business            Business                     @relation(fields: [businessId], references: [id])
  quotaItems          MembershipPackageQuotaItem[]
  customerMemberships CustomerMembership[]

  @@index([businessId, isActive])
}

model MembershipPackageQuotaItem {
  id            String @id @default(uuid())
  templateId    String @map("template_id")
  serviceId     String @map("service_id")
  quotaAmount   Float  @default(0) @map("quota_amount")
  deductionRate Float  @default(1) @map("deduction_rate")
  createdAt     DateTime @default(now()) @map("created_at")

  template MembershipPackageTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)
  service  Service                   @relation(fields: [serviceId], references: [id])

  @@unique([templateId, serviceId])
}

enum MembershipStatus {
  ACTIVE
  EXPIRED
  CANCELLED
}

model CustomerMembership {
  id         String   @id @default(uuid())
  businessId String   @map("business_id")
  customerId String   @map("customer_id")
  templateId String   @map("template_id")

  startAt DateTime @map("start_at")
  endAt   DateTime @map("end_at")
  status  MembershipStatus @default(ACTIVE)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  customer     Customer                       @relation(fields: [customerId], references: [id], onDelete: Cascade)
  template     MembershipPackageTemplate      @relation(fields: [templateId], references: [id])
  balances     CustomerMembershipQuotaBalance[]
  usageLogs    CustomerMembershipUsageLog[]
  transactions Transaction[]

  @@index([businessId, status])
  @@index([customerId, status])
}

model CustomerMembershipQuotaBalance {
  id                   String @id @default(uuid())
  customerMembershipId String @map("customer_membership_id")
  serviceId            String @map("service_id")
  initialQty           Float  @map("initial_qty")
  remainingQty         Float  @map("remaining_qty")
  createdAt            DateTime @default(now()) @map("created_at")

  customerMembership CustomerMembership @relation(fields: [customerMembershipId], references: [id], onDelete: Cascade)
  service            Service            @relation(fields: [serviceId], references: [id])

  @@unique([customerMembershipId, serviceId])
}

model CustomerMembershipUsageLog {
  id                   String @id @default(uuid())
  businessId           String @map("business_id")
  customerMembershipId String @map("customer_membership_id")
  transactionId        String @map("transaction_id")
  serviceId            String @map("service_id")
  usedQty              Float  @map("used_qty")
  coveredAmount        Int    @map("covered_amount")
  payableAmount        Int    @map("payable_amount")
  createdAt            DateTime @default(now()) @map("created_at")

  customerMembership CustomerMembership @relation(fields: [customerMembershipId], references: [id], onDelete: Cascade)
  transaction        Transaction        @relation(fields: [transactionId], references: [id], onDelete: Cascade)
  service            Service            @relation(fields: [serviceId], references: [id])

  @@index([businessId, createdAt])
}

// =============================================
// ENUMS
// =============================================
enum Status {
  PENDING
  PROSES
  SELESAI
  DIAMBIL
}

enum Payment {
  CASH
  QRIS
}
