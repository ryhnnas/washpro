# ============================================================
# WashPro — Environment Variables
# Salin ke .env dan isi sesuai kebutuhan. JANGAN commit .env.
# ============================================================
#
# Variabel mana yang dipakai?
#   Docker Compose (VPS/production): JWT_*, MYSQL_*, FRONTEND_*,
#     GOWA_*, QRIS_*, SUPERADMIN_PHONE, SMTP_*
#   npm run dev (lokal tanpa Docker): DATABASE_URL, PORT, NODE_ENV,
#     VITE_API_URL, + semua backend vars di atas
#
# Catatan Docker:
#   - DATABASE_URL backend di-set otomatis oleh docker-compose.yml
#   - NODE_ENV backend = production (hardcoded di compose)
#   - VITE_API_URL build Docker = /api (hardcoded di compose, abaikan baris VITE di bawah)
#

# ============================================================
# WAJIB — JWT (Docker & dev)
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
# JWT_SECRET dan SUPERADMIN_JWT_SECRET HARUS berbeda
# ============================================================
JWT_SECRET=your-tenant-jwt-secret-here
SUPERADMIN_JWT_SECRET=your-superadmin-jwt-secret-here

# ============================================================
# DOCKER COMPOSE — Database
# ============================================================
MYSQL_ROOT_PASSWORD=change-me-root
MYSQL_DATABASE=washpro
MYSQL_USER=washpro
MYSQL_PASSWORD=change-me-db
MYSQL_PORT=3306
# Bind ke localhost (aman di VPS). Untuk akses MySQL dari LAN: MYSQL_BIND=0.0.0.0
MYSQL_BIND=127.0.0.1

# ============================================================
# DOCKER COMPOSE — App & reverse proxy
# ============================================================
FRONTEND_PORT=8080
# Bind ke localhost; Caddy/Nginx di host proxy ke sini. LAN dev: FRONTEND_BIND=0.0.0.0
FRONTEND_BIND=127.0.0.1
# Lokal Docker: http://localhost:8080
# VPS production: https://app.domainanda.com (wajib HTTPS — cookie auth butuh Secure)
FRONTEND_URL=http://localhost:8080

# ============================================================
# DEV LOKAL — Backend tanpa Docker
# ============================================================
# Format: mysql://user:password@host:port/dbname
# Pool (opsional, append ke URL): ?connection_limit=10&pool_timeout=10
DATABASE_URL="mysql://washpro:password@localhost:3306/washpro"
PORT=5000
NODE_ENV=development

# ============================================================
# DEV LOKAL — Frontend Vite (npm run dev)
# Tidak dipakai saat build Docker (compose pakai VITE_API_URL=/api)
# ============================================================
VITE_API_URL=http://localhost:5000/api

# ============================================================
# SUPERADMIN
# ============================================================
# Nomor WA notifikasi pembayaran masuk (format: 628xxx, tanpa +)
SUPERADMIN_PHONE=

# ============================================================
# WHATSAPP GATEWAY (GOWA)
# ============================================================
# false = nonaktifkan semua fitur WA
GOWA_ENABLED=false
# Dev lokal (GOWA di host):     http://localhost:3000/
# Docker (GOWA di host/VPS):    http://host.docker.internal:3000/
# GOWA di container/server lain: http://<ip-atau-hostname>:3000/
GOWA_API_URL=http://localhost:3000/
GOWA_USERNAME=admin
GOWA_PASSWORD=admin

# ============================================================
# QRIS PAYMENT (backend only — jangan taruh di frontend)
# ============================================================
QRIS_STATIC_PAYLOAD=
QRIS_MERCHANT_NAME=WashPro
QRIS_MERCHANT_BANK=QRIS

# ============================================================
# EMAIL (SMTP) — backend only
# Tanpa SMTP_USER/SMTP_PASS, email hanya dicetak ke log (dev fallback)
# ============================================================
SMTP_HOST=mail.example.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM="WashPro <no-reply@example.com>"
# Set true jika sertifikat TLS SMTP self-signed / expired (hindari di production)
# SMTP_ALLOW_INSECURE_TLS=false

# ============================================================
# OPSIONAL — Logging
# ============================================================
# LOG_LEVEL=info

# ============================================================
# OPSIONAL — Dev/E2E saja (JANGAN aktifkan di production)
# ============================================================
# DISABLE_RATE_LIMIT=true

# ============================================================
# SEED — Bootstrap DB (jalankan sekali, jangan pakai default di production)
# docker compose exec backend sh -c 'SEED_SUPERADMIN_PASSWORD="..." npm run db:seed'
# ============================================================
# SEED_SUPERADMIN_PASSWORD=
# SEED_OWNER_PASSWORD=
# SEED_STAFF_PASSWORD=
