# ============================================================
# WashPro — Environment Variables
# Salin file ini ke .env dan isi sesuai konfigurasi Anda.
# JANGAN commit file .env ke version control.
# ============================================================

# --- DATABASE ---
# Format: mysql://user:password@host:port/dbname
DATABASE_URL="mysql://user:password@localhost:3306/washpro"
# Connection pool params (append to URL): ?connection_limit=10&pool_timeout=10

# --- BACKEND ---
PORT=5000
NODE_ENV=development

# --- JWT SECRETS ---
# Generate dengan: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
# PENTING: JWT_SECRET dan SUPERADMIN_JWT_SECRET HARUS berbeda
JWT_SECRET=your-tenant-jwt-secret-here
SUPERADMIN_JWT_SECRET=your-superadmin-jwt-secret-here

# --- SUPERADMIN ---
# Nomor WA untuk menerima notifikasi pembayaran masuk (format: 628xxx)
SUPERADMIN_PHONE=

# --- WHATSAPP GATEWAY (GOWA) ---
# Jalankan: docker run -p 3000:3000 aldinokemal2104/go-whatsapp-web-multidevice
GOWA_ENABLED=true
GOWA_API_URL=http://localhost:3000/
GOWA_USERNAME=admin
GOWA_PASSWORD=admin

# --- QRIS PAYMENT ---
# Isi dengan payload QRIS statis dari merchant Anda (dari aplikasi QRIS bank/e-wallet)
# Payload ini disimpan di backend, TIDAK di frontend
QRIS_STATIC_PAYLOAD=
QRIS_MERCHANT_NAME=WashPro
QRIS_MERCHANT_BANK=QRIS

# --- FRONTEND (Vite) ---
VITE_API_URL=http://localhost:5000/api

# --- OPTIONAL ---
# URL frontend untuk CORS whitelist di production
# FRONTEND_URL=https://yourdomain.com
